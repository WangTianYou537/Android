-	 * to correctly detect memory initialisation. Make sure one is called
-	 * directly since our indirection trick above successfully confuses it.
-	 */
 #if defined(__has_feature)
 # if __has_feature(memory_sanitizer)
 	memset(p, 0, n);
 # endif
 #endif
-
 	ssh_bzero(p, n);
 }
+#endif
 
